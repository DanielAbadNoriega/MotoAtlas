# MotoAtlas Supabase import
# Copia este archivo como .env.import y NUNCA lo subas al repo.
# Usa la service role key solo en scripts de backend/local, jamás en Vite/frontend.
# API_NINJAS_KEY es opcional y solo se usa en scripts de importación, no en frontend.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
API_NINJAS_KEY=
